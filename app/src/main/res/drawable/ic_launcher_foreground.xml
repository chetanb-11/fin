<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing radial gold backdrop center -->
    <path
        android:pathData="M54,54m-28,0a28,28 0,1 1,56 0a28,28 0,1 1,-56 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="26"
                android:endX="54"
                android:endY="82"
                android:type="radial"
                android:gradientRadius="35">
                <item android:offset="0.0" android:color="#25FFD700" /> <!-- Golden glow -->
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- The Golden Coin (centered at 54, 38) -->
    <path
        android:pathData="M54,38m-14,0a14,14 0,1 1,28 0a14,14 0,1 1,-28 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="40"
                android:startY="24"
                android:endX="68"
                android:endY="52"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFE082" /> <!-- Light Warm Gold -->
                <item android:offset="1.0" android:color="#FFB300" /> <!-- Rich Amber Gold -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coin inner ring detailing -->
    <path
        android:pathData="M54,38m-10,0a10,10 0,1 1,20 0a10,10 0,1 1,-20 0"
        android:fillColor="#00000000"
        android:strokeWidth="1.5"
        android:strokeColor="#FF8F00" />

    <!-- Stylized "F" letter inside the coin (for Finbox) -->
    <path
        android:pathData="M51,32 h6 c0.8,0 1.2,0.4 1.2,1.0 c0,0.6 -0.4,1.0 -1.2,1.0 h-4 v3 h4 c0.8,0 1.2,0.4 1.2,1.0 c0,0.6 -0.4,1.0 -1.2,1.0 h-4 v4 c0,0.8 -0.4,1.2 -1.0,1.2 c-0.6,0 -1.0,-0.4 -1.0,-1.2 z"
        android:fillColor="#E65100" />

    <!-- Top motion speed line -->
    <path
        android:pathData="M54,16 L54,20"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeColor="#40FFCA28" />

    <!-- Inside back wall/shadow of the inbox tray -->
    <path
        android:pathData="M32,58 h44 v10 h-44 z"
        android:fillColor="#100829" />

    <!-- The Premium Amethyst Inbox Tray Frame -->
    <path
        android:pathData="M32,58 L32,74 C32,76.2 33.8,78 36,78 h36 C74.2,78 76,76.2 76,74 L76,58 L70,58 L70,68 C70,69.1 69.1,70 68,70 H40 C38.9,70 38,69.1 38,68 L38,58 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="32"
                android:startY="58"
                android:endX="76"
                android:endY="78"
                android:type="linear">
                <item android:offset="0.0" android:color="#9C27B0" /> <!-- Premium Violet -->
                <item android:offset="1.0" android:color="#EC407A" /> <!-- Vivid Rose Pink -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Neon fuchsia glow line defining the tray entrance lip -->
    <path
        android:pathData="M38,58 L38,68 C38,69.1 38.9,70 40,70 h28 C69.1,70 70,69.1 70,68 L70,58"
        android:fillColor="#00000000"
        android:strokeWidth="1.5"
        android:strokeColor="#FF4081" />

</vector>
